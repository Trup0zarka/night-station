checkpoint-setup = [color=#d1d5db]SCANNER:[/color] An improvised checkpoint is being established on the route through this sector.
checkpoint-hold = [color=#d1d5db]SCANNER:[/color] Traffic is slowing to a crawl as armed inspectors squeeze the corridor.
checkpoint-raid = [color=#ff4444]ALERT:[/color] The checkpoint has turned into a live seizure operation. Armed personnel are engaging targets on sight.
checkpoint-standdown = [color=#d1d5db]SCANNER:[/color] The pressure eases. The inspectors appear satisfied or unwilling to push further.
checkpoint-exit = [color=#d1d5db]SCANNER:[/color] The checkpoint is coming apart and the enforcement crew is leaving the route behind.
