<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
  	<add key="nuget" value="https://api.nuget.org/v3/index.json" />
    <!-- dotnet-eng источник отключен - сервер Azure DevOps больше не доступен публично -->
    <!-- <add key="dotnet-eng" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-eng/nuget/v3/index.json" /> -->
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget">
      <package pattern="*" />
    </packageSource>
    <!-- <packageSource key="dotnet-eng">
      <package pattern="Microsoft.DotNet.RemoteExecutor" />
    </packageSource> -->
  </packageSourceMapping>

  <config>
    <!-- Отключаем проверку уязвимостей пакетов чтобы избежать ошибок NU1900 -->
    <add key="nugetauditmode" value="none" />
  </config>
</configuration>
